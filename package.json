{
  "name": "sonos2mqtt",
  "version": "0.0.0-development",
  "description": "Control and monitor Sonos speakers through MQTT",
  "main": "lib/index.js",
  "license": "MIT",
  "author": "Stephan van Rooij <sonos2mqtt@svrooij.io> (https://svrooij.io)",
  "bin": {
    "sonos2mqtt": "lib/index.js"
  },
  "keywords": [
    "sonos",
    "mqtt-smarthome",
    "mqtt",
    "music control"
  ],
  "preferGlobal": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc --skipLibCheck",
    "help": "node ./lib/index.js --help",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "serve-docs": "docker compose -f ./docs/docker-compose.yml up jekyll",
    "start-docs-container": "docker compose -f ./docs/docker-compose.yml run --entrypoint /bin/sh jekyll",
    "test": "npm run lint && npm run build && npm run test:unit",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@svrooij/sonos": "^2.7.0-beta.3",
    "mqtt": "5.10.3",
    "serilogger": "^0.5.0",
    "typed-emitter": "^2.1.0",
    "yalm": "4.1.0",
    "yargs": "17.7.2"
  },
  "devDependencies": {
    "@types/debug": "4.1.12",
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.1",
    "@types/yargs": "^17.0.35",
    "aedes": "^1.1.1",
    "eslint": "^9.39.4",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/svrooij/sonos2mqtt.git"
  },
  "bugs": {
    "url": "https://github.com/svrooij/sonos2mqtt/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/svrooij"
  },
  "files": [
    "README.md",
    "LICENSE",
    "lib/**/*.ts",
    "lib/**/*.js"
  ]
}
